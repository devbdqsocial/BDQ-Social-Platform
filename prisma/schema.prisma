// BDQ Social — canonical schema. See Docs/SCHEMA.md for rationale.
// Money is integer paise. IDs are cuid(). Pricing is dynamic (admin-entered per event).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (runtime)
  directUrl = env("DATABASE_URL_DIRECT") // direct (migrations)
}

// ──────────────────────────── ENUMS ────────────────────────────
enum Role {
  CUSTOMER
  VENDOR
  STAFF
  ADMIN
  SUPER_ADMIN
}

enum Permission {
  CHECKIN
  VENDOR_MANAGE
  VENDOR_VIEW
  ARTIST_MANAGE
  ARTIST_VIEW
  EVENT_VIEW
  CUSTOMER_VIEW
  PAYMENT_VIEW
  TICKETS_MANAGE
  FINANCE_MANAGE
}

enum EventStatus {
  DRAFT
  PUBLISHED
  LIVE
  ENDED
  ARCHIVED
}

enum TicketStatus {
  VALID
  CHECKED_IN
  CANCELLED
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}

enum PaymentGateway {
  RAZORPAY
  OFFLINE
}

enum PaymentMode {
  ONLINE
  OFFLINE
}

enum PaymentStatus {
  CREATED
  CAPTURED
  FAILED
}

enum CouponType {
  FLAT
  PERCENT
}

enum DiscountSource {
  NONE
  EARLY_BIRD
  BULK
  COUPON
}

enum StallStatus {
  AVAILABLE
  HELD
  PENDING
  BOOKED
  BLOCKED
}

enum StallKind {
  STALL
  INFRA
}

enum VendorApproval {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum BookingStatus {
  RESERVED // vendor picked a stall during onboarding; held while the application is open
  HELD // short live-payment hold (legacy ticket-style)
  PENDING_PAYMENT // admin approved + confirmed the stall; awaiting vendor payment (payBy window)
  PENDING // legacy: payment captured, awaiting admin verification
  BOOKED
  REJECTED
  CANCELLED
}

enum BookingSource {
  VENDOR
  ADMIN
}

enum AssetKind {
  LOGO
  BANNER
  PRODUCT
  KYC_DOC
}

enum ContractStatus {
  SENT
  SIGNED
}

enum ArtistType {
  MUSICIAN
  BAND
  DJ
  PERFORMER
  DANCE
  COMEDIAN
  SPEAKER
  HOST_MC
  OTHER
}

enum ArtistBookingStatus {
  INQUIRY
  NEGOTIATING
  CONFIRMED
  CANCELLED
}

enum ArtistSettlement {
  UNPAID
  PARTIAL
  PAID
}

enum SponsorTier {
  TITLE
  POWERED_BY
  ZONE
  STALL
  ASSOCIATE
}

enum WaitlistType {
  TICKET
  STALL
}

enum WaitlistSource {
  PLATFORM
  EVENT
}

enum CheckInDirection {
  IN
  OUT
}

enum NotifChannel {
  WHATSAPP
  EMAIL
  SMS
  PUSH
}

enum NotifStatus {
  QUEUED
  SENT
  FAILED
}

// ──────────────────────────── IDENTITY ─────────────────────────
model User {
  id           String       @id @default(cuid())
  role         Role         @default(CUSTOMER)
  phone        String?      @unique
  email        String?      @unique
  name         String?
  firebaseUid  String?      @unique
  permissions  Permission[] @default([])
  passwordHash String?
  totpSecret   String?
  totpEnabled  Boolean      @default(false)
  // Secret held mid-enrolment (self-service 2FA) until a code confirms it; promoted to totpSecret on confirm.
  totpPendingSecret String?
  // SHA-256 hashes of one-time backup codes; one is consumed (removed) per recovery login.
  recoveryCodes String[]     @default([])
  tokenVersion Int          @default(0)
  // Admin/staff profile + preferences (self-service My Profile).
  photoUrl     String?
  designation  String?
  whatsapp     String?
  prefs        Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  orders            Order[]
  vendorProfile     VendorProfile?
  checkIns          CheckIn[]          @relation("ScannedBy")
  auditLogs         AuditLog[]
  waitlist          Waitlist[]
  couponRedemptions CouponRedemption[]

  @@index([role])
}

// ──────────────────────────── EVENT CORE ───────────────────────
model Event {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  location    String?
  mapLink     String?
  startsAt    DateTime
  endsAt      DateTime
  status      EventStatus @default(DRAFT)
  theme       Json?
  bulkTiers   Json?
  earlyBird   Json?
  capacity    Int?
  createdById String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  archiveJson Json?

  ticketTypes      TicketType[]
  schedule         ScheduleItem[]
  stallTypes       StallTypeDef[]
  stalls           Stall[]
  mapLayout        MapLayout?
  orders           Order[]
  coupons          Coupon[]
  bookings         Booking[]
  sponsors         Sponsor[]
  waitlist         Waitlist[]
  leads            Lead[]
  expenses         Expense[]
  budgets          Budget[]
  expenseSchedules ExpenseSchedule[]
  galleryPhotos    GalleryPhoto[]
  offers           Offer[]
  addOns           StallAddOn[]
  happenings       HappeningItem[]
  artistBookings   ArtistBooking[]
  mapId            String?

  @@index([status])
}

enum OfferKind {
  DISCOUNT
  FREEBIE
  BUNDLE
}

enum OfferStatus {
  DRAFT
  PUBLISHED
  ENDED
}

/** Vendor/sponsor offers (customer-portal §3.6, admin-portal §6.1). Shown to customers only when
 *  PUBLISHED; greys to "Ended" past `endsAt`. Redemption is a soft count (no auth in V1). */
model Offer {
  id              String         @id @default(cuid())
  eventId         String
  event           Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  vendorProfileId String?
  vendorProfile   VendorProfile? @relation(fields: [vendorProfileId], references: [id], onDelete: SetNull)
  sponsorId       String?
  sponsor         Sponsor?       @relation(fields: [sponsorId], references: [id], onDelete: SetNull)
  title           String
  terms           String
  kind            OfferKind      @default(DISCOUNT)
  startsAt        DateTime
  endsAt          DateTime
  status          OfferStatus    @default(DRAFT)
  maxRedemptions  Int?
  redeemedCount   Int            @default(0)
  createdAt       DateTime       @default(now())

  @@index([eventId, status, endsAt])
  @@index([vendorProfileId])
}

/** Post-event gallery (customer-portal §3.8). Curated in the admin Content group; the public
 *  gallery shows only `published` photos and only when there are ≥8 (avoid a hollow launch). */
model GalleryPhoto {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  url       String
  publicId  String
  caption   String?
  sortOrder Int      @default(0)
  published Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([eventId, published, sortOrder])
}

model TicketType {
  id              String   @id @default(cuid())
  eventId         String
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name            String
  priceInPaise    Int
  earlyPricePaise Int?
  totalQty        Int
  soldQty         Int      @default(0)
  attendeesPer    Int      @default(1)
  tickets         Ticket[]

  @@index([eventId])
}

model ScheduleItem {
  id          String    @id @default(cuid())
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  startsAt    DateTime
  endsAt      DateTime?
  title       String
  stageOrZone String?
  performer   String?
  sortOrder   Int       @default(0)
  artistBooking ArtistBooking?

  @@index([eventId, startsAt])
}

// ──────────────────────────── MAP / STALLS ─────────────────────
model StallTypeDef {
  id           String  @id @default(cuid())
  eventId      String
  event        Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name         String
  widthFt      Float
  heightFt     Float
  priceInPaise Int
  color        String
  sellable     Boolean @default(true)
  stalls       Stall[]

  @@unique([eventId, name])
}

model MapLayout {
  id           String   @id @default(cuid())
  eventId      String   @unique
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  layoutJson   Json
  opsLayerJson Json?
  version      Int      @default(1)
  updatedAt    DateTime @updatedAt
}

// Reusable, event-independent layout (canvas + elements + stall types). Cloned onto an event.
model LayoutTemplate {
  id          String   @id @default(cuid())
  name        String
  layoutJson  Json
  createdById String?
  createdAt   DateTime @default(now())
}

// Global, reusable map-element catalog (stall sizes + infra). Dropped onto any map.
model MapElement {
  id        String   @id @default(cuid())
  name      String
  kind      String   @default("STALL") // STALL | INFRA
  widthFt   Float
  heightFt  Float
  color     String
  sellable  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// A named, reusable map (venue size + layout). Attach to any event. Geometry stored in feet.
// Canonical venue model (R5.5 — designated as VenueMap; see Docs/audit/venue-map-audit.md).
// `layoutJson` is the single LayoutV2 document. `legacyTemplateId` records provenance when a legacy
// LayoutTemplate has been additively folded in (no drops).
model EventMap {
  id               String   @id @default(cuid())
  name             String
  description      String?
  locationName     String?
  unit             String   @default("FT") // FT | M (display only; stored in feet)
  widthFt          Float
  heightFt         Float
  gridFt           Float    @default(5)
  layoutJson       Json
  legacyTemplateId String?  @unique // set when migrated from a LayoutTemplate (R5.5 Phase 4)
  createdById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Stall {
  id           String        @id @default(cuid())
  eventId      String
  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  kind         StallKind     @default(STALL)
  stallTypeId  String?
  stallType    StallTypeDef? @relation(fields: [stallTypeId], references: [id])
  label        String
  xFt          Float
  yFt          Float
  widthFt      Float
  heightFt     Float
  rotation     Float         @default(0)
  priceInPaise Int?
  status       StallStatus   @default(AVAILABLE)
  holdUntil    DateTime?
  holdUserId   String?
  bookings     Booking[]

  @@unique([eventId, label])
  @@index([eventId, status])
}

// ──────────────────────────── ORDERS / TICKETS ─────────────────
model Order {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  eventId        String
  event          Event          @relation(fields: [eventId], references: [id])
  status         OrderStatus    @default(PENDING)
  subtotal       Int
  discount       Int            @default(0)
  total          Int
  discountSource DiscountSource @default(NONE)
  couponId       String?
  coupon         Coupon?        @relation(fields: [couponId], references: [id])
  gatewayOrderId String?        @unique
  items          Json?
  utm            Json?
  expiresAt      DateTime?
  createdAt      DateTime       @default(now())

  tickets           Ticket[]
  payments          Payment[]
  couponRedemptions CouponRedemption[]

  @@index([userId, status])
  @@index([eventId, status])
}

model Ticket {
  id           String       @id @default(cuid())
  orderId      String
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketTypeId String
  ticketType   TicketType   @relation(fields: [ticketTypeId], references: [id])
  holderName   String?
  holderPhone  String?
  holderEmail  String?
  qrToken      String       @unique
  status       TicketStatus @default(VALID)
  isComp       Boolean      @default(false)
  /// Group-QR (M1): one ticket per order line; one QR admits the whole group.
  admitCount   Int          @default(1)
  createdAt    DateTime     @default(now())

  checkIns CheckIn[]

  @@index([orderId])
}

model Payment {
  id           String         @id @default(cuid())
  orderId      String?
  order        Order?         @relation(fields: [orderId], references: [id])
  bookingId    String?        @unique
  booking      Booking?       @relation(fields: [bookingId], references: [id])
  addOnOrderId String?            @unique
  addOnOrder   BookingAddOnOrder? @relation(fields: [addOnOrderId], references: [id])
  gateway      PaymentGateway
  mode         PaymentMode
  gatewayRef   String?        @unique
  amount       Int
  feePaise     Int? // gateway fee (Razorpay), captured from webhook/reconcile
  taxPaise     Int? // tax on the gateway fee (GST on Razorpay fee, not on the sale)
  status       PaymentStatus  @default(CREATED)
  recordedById String?
  meta         Json?
  createdAt    DateTime       @default(now())

  @@index([orderId])
  @@index([createdAt]) // reconciliation/date-range queries
  @@index([status, createdAt]) // admin finance aggregates (captured payments by date)
}

model Coupon {
  id           String             @id @default(cuid())
  eventId      String?
  event        Event?             @relation(fields: [eventId], references: [id])
  code         String             @unique
  type         CouponType
  value        Int
  maxUses      Int?
  usedCount    Int                @default(0)
  perUserLimit Int                @default(1)
  minOrder     Int?
  scope        Json?
  startsAt     DateTime?
  endsAt       DateTime?
  active       Boolean            @default(true)
  orders       Order[]
  redemptions  CouponRedemption[]
}

/// Per-(coupon,user,order) redemption record. The (couponId,userId,orderId) unique index makes
/// per-user coupon limit enforcement race-safe (see src/server/tickets/service.ts).
model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([couponId, userId, orderId])
  @@index([couponId, userId])
}

// ──────────────────────────── VENDORS ──────────────────────────
model VendorProfile {
  id               String         @id @default(cuid())
  userId           String         @unique
  user             User           @relation(fields: [userId], references: [id])
  brandName        String
  registeredName   String? // legal/registered business name (vs public brand name)
  category         String?
  productCategory  String? // structured dropdown taxonomy
  products         String? // free text — what they sell
  description      String?
  website          String?
  instagram        String?
  contactPerson    String?
  whatsapp         String?
  city             String?
  socials          Json?
  approvalStatus   VendorApproval @default(SUBMITTED)
  verifiedCallById String?
  verifiedAt       DateTime?
  callbackNote     String? // admin note logged on the verification call-back
  callbackAt       DateTime?
  createdAt        DateTime       @default(now())

  kyc      VendorKyc?
  assets   VendorAsset[]
  contract VendorContract?
  bookings Booking[]
  leads    Lead[]
  expenses Expense[]
  offers   Offer[]
}

model VendorKyc {
  id              String        @id @default(cuid())
  vendorProfileId String        @unique
  vendorProfile   VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  pan             String?
  fssai           String?
  gstin           String?
  docUrls         Json?
}

model VendorAsset {
  id              String        @id @default(cuid())
  vendorProfileId String
  vendorProfile   VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  kind            AssetKind
  url             String
  publicId        String
  createdAt       DateTime      @default(now())

  @@index([vendorProfileId])
}

model VendorContract {
  id              String         @id @default(cuid())
  vendorProfileId String         @unique
  vendorProfile   VendorProfile  @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  status          ContractStatus @default(SENT)
  url             String? // Cloudinary URL of the generated, e-signed PDF
  version         String? // contract template version signed
  signerName      String? // typed legal name at signing
  signerIp        String? // captured at signing (audit trail)
  signedAt        DateTime?
}

// ──────────────────────────── ARTISTS / TALENT ─────────────────
// Admin-managed roster (no artist login). Per-event engagement, negotiated pricing, set timing that
// auto-publishes to the schedule, and settlement via TALENT expenses → P&L.
model ArtistProfile {
  id              String          @id @default(cuid())
  stageName       String
  realName        String?
  type            ArtistType      @default(MUSICIAN)
  genre           String?
  bio             String?
  city            String?
  phone           String?
  whatsapp        String?
  email           String?
  instagram       String?
  socials         Json?
  askingFeePaise  Int? // rate card / quoted fee (negotiable per booking)
  notes           String? // internal roster notes
  slug            String?         @unique // public lineup page
  publicVisible   Boolean         @default(false)
  attributionCode String?         @unique // maps order.utm.source → this artist for sales attribution
  archived        Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  assets   ArtistAsset[]
  bookings ArtistBooking[]

  @@index([type])
}

model ArtistAsset {
  id        String        @id @default(cuid())
  artistId  String
  artist    ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  kind      String // PHOTO | REEL | RIDER
  url       String
  publicId  String?
  createdAt DateTime      @default(now())

  @@index([artistId])
}

model ArtistBooking {
  id                  String              @id @default(cuid())
  eventId             String
  event               Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  artistId            String
  artist              ArtistProfile       @relation(fields: [artistId], references: [id])
  status              ArtistBookingStatus @default(INQUIRY)
  agreedFeePaise      Int                 @default(0) // negotiated fee (money out)
  settlement          ArtistSettlement    @default(UNPAID) // derived from payouts vs agreed fee
  setStartsAt         DateTime?
  setEndsAt           DateTime?
  stageOrZone         String?
  published           Boolean             @default(true) // show this set on the public lineup
  negotiationNote     String?
  negotiationAt       DateTime?
  scheduleItemId      String?             @unique // materialized public schedule slot
  scheduleItem        ScheduleItem?       @relation(fields: [scheduleItemId], references: [id])
  presentedBySponsorId String?
  presentedBySponsor  Sponsor?            @relation(fields: [presentedBySponsorId], references: [id])
  contract            ArtistContract?
  payouts             Expense[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([eventId, status])
  @@index([artistId])
}

model ArtistContract {
  id         String         @id @default(cuid())
  bookingId  String         @unique
  booking    ArtistBooking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  status     ContractStatus @default(SENT)
  url        String? // Cloudinary URL of the e-signed PDF
  version    String?
  signerName String?
  signerIp   String?
  signedAt   DateTime?
  signToken  String         @unique // public tokenized e-sign link (artists have no login)
}

model Booking {
  id              String         @id @default(cuid())
  eventId         String
  event           Event          @relation(fields: [eventId], references: [id])
  stallId         String
  stall           Stall          @relation(fields: [stallId], references: [id])
  vendorProfileId String?
  vendorProfile   VendorProfile? @relation(fields: [vendorProfileId], references: [id])
  source          BookingSource  @default(VENDOR)
  adminDetails    Json?
  status          BookingStatus  @default(HELD)
  gatewayOrderId  String?        @unique
  payBy           DateTime? // deadline to pay after admin approval (RESERVED→PENDING_PAYMENT window)
  payment         Payment?
  addOnOrders     BookingAddOnOrder[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  // "one active booking per stall" is enforced by a partial unique index (raw SQL migration,
  // see Docs/SCHEMA.md §4).

  @@index([stallId, status])
  @@index([eventId, status])
}

// ──────────────────────────── OPS / GROWTH ─────────────────────
model CheckIn {
  id           String           @id @default(cuid())
  ticketId     String
  ticket       Ticket           @relation(fields: [ticketId], references: [id])
  scannedById  String
  scannedBy    User             @relation("ScannedBy", fields: [scannedById], references: [id])
  gate         String?
  direction    CheckInDirection @default(IN)
  /// Group-QR (M1): people admitted by THIS scan (partial admits sum to Ticket.admitCount).
  admitted     Int              @default(1)
  clientScanId String?          @unique
  scannedAt    DateTime         @default(now())

  @@index([ticketId])
  @@index([direction, scannedAt]) // dashboard gate/time-range check-in aggregates
}

model Sponsor {
  id          String            @id @default(cuid())
  eventId     String
  event       Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name        String
  tier        SponsorTier
  logoUrl     String?
  placements  Json?
  leadAccess  Boolean           @default(false)
  amountPaise Int               @default(0)
  status      SponsorshipStatus @default(PROPOSED)
  paidAt      DateTime?
  note        String?
  createdAt   DateTime          @default(now())
  offers      Offer[]
  artistBookings ArtistBooking[]

  @@index([eventId])
}

model Waitlist {
  id         String         @id @default(cuid())
  source     WaitlistSource @default(EVENT)
  eventId    String?
  event      Event?         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type       WaitlistType   @default(TICKET)
  userId     String?
  user       User?          @relation(fields: [userId], references: [id])
  name       String?
  email      String?
  phone      String?
  contact    String?
  meta       Json?
  notifiedAt DateTime?
  createdAt  DateTime       @default(now())

  @@index([eventId, type])
  @@index([source])
}

model Lead {
  id              String        @id @default(cuid())
  eventId         String
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  vendorProfileId String
  vendorProfile   VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  name            String?
  phone           String?
  email           String?
  consent         Boolean       @default(true)
  createdAt       DateTime      @default(now())

  @@index([vendorProfileId])
  @@index([eventId])
}

// ──────────────────────────── DELIVERY / AUDIT ─────────────────
model Outbox {
  id         String       @id @default(cuid())
  channel    NotifChannel
  toAddress  String
  template   String
  payload    Json
  status     NotifStatus  @default(QUEUED)
  attempts   Int          @default(0)
  lastError  String?
  dedupeKey  String       @unique
  campaignId String?
  campaign   Campaign?    @relation(fields: [campaignId], references: [id])
  createdAt  DateTime     @default(now())
  sentAt     DateTime?

  @@index([status])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  role      Role?
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([entity, entityId, createdAt])
  @@index([actorId, createdAt])
}

model RateLimit {
  key     String   @id
  count   Int      @default(0)
  resetAt DateTime
}

// ──────────────────────────── FINANCE LEDGER ───────────────────
// Cost side of the books (revenue lives in Order/Payment/Booking). Money is integer paise.
// Every mutation here is audited (withAudit). Net revenue = captured − Payment.feePaise − taxPaise.

enum ExpenseCategory {
  VENUE
  MARKETING
  STAFF
  SECURITY
  LOGISTICS
  PRODUCTION // stage, sound, lights
  TALENT // performers / artists
  FNB // food & beverage procurement
  PERMIT // licenses, permits
  VENDOR_PAYOUT // outgoing payment to a vendor
  MISC
}

enum ExpenseStatus {
  DRAFT
  APPROVED
  PAID
}

enum ExpenseCadence {
  WEEKLY
  MONTHLY
}

enum SponsorshipStatus {
  PROPOSED
  SIGNED
  PAID
}

enum SettlementStatus {
  RECONCILED
  UNMATCHED
}

model Expense {
  id              String           @id @default(cuid())
  eventId         String? // null = org-wide overhead (not tied to one event)
  event           Event?           @relation(fields: [eventId], references: [id])
  category        ExpenseCategory
  vendorProfileId String? // optional counterparty (e.g. VENDOR_PAYOUT)
  vendorProfile   VendorProfile?   @relation(fields: [vendorProfileId], references: [id])
  artistBookingId String? // optional counterparty (TALENT payout to an artist booking)
  artistBooking   ArtistBooking?   @relation(fields: [artistBookingId], references: [id])
  title           String
  amountPaise     Int
  incurredAt      DateTime
  status          ExpenseStatus    @default(DRAFT)
  receiptUrl      String? // Cloudinary
  note            String?
  scheduleId      String? // set when materialized from an ExpenseSchedule
  schedule        ExpenseSchedule? @relation(fields: [scheduleId], references: [id])
  recordedById    String?
  approvedById    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([eventId, category])
  @@index([eventId, incurredAt])
}

model Budget {
  id           String          @id @default(cuid())
  eventId      String
  event        Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  category     ExpenseCategory
  plannedPaise Int

  @@unique([eventId, category])
}

model ExpenseSchedule {
  id          String          @id @default(cuid())
  eventId     String?
  event       Event?          @relation(fields: [eventId], references: [id])
  category    ExpenseCategory
  title       String
  amountPaise Int
  cadence     ExpenseCadence
  nextRunAt   DateTime
  remaining   Int? // installments left; null = open-ended recurring
  active      Boolean         @default(true)
  generated   Expense[]
  createdAt   DateTime        @default(now())

  @@index([active, nextRunAt])
}

model Settlement {
  id          String           @id @default(cuid())
  gatewayRef  String           @unique // Razorpay settlement id / UTR
  amountPaise Int
  feePaise    Int
  taxPaise    Int
  settledAt   DateTime
  status      SettlementStatus @default(UNMATCHED)
  meta        Json?
  createdAt   DateTime         @default(now())

  @@index([settledAt])
}

// In-app admin notifications (alerts feed + header bell). Additive.
model Notification {
  id        String    @id @default(cuid())
  type      String
  title     String
  body      String?
  href      String?
  eventId   String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([readAt, createdAt])
  @@index([eventId])
}

enum CampaignStatus {
  DRAFT
  PROCESSING
  SCHEDULED
  PAUSED
  CANCELLED
  COMPLETED
  FAILED
}

// Marketing campaigns (WhatsApp / email). Additive.
model Campaign {
  id             String         @id @default(cuid())
  name           String
  channel        NotifChannel   @default(EMAIL)
  eventId        String?
  audience       String         @default("ALL")
  targeting      Json? // Stores segment rules (e.g. { role: "VENDOR" })
  subject        String?
  body           String?
  status         CampaignStatus @default(DRAFT)
  sentCount      Int            @default(0)
  stats          Json? // Stores analytics: { delivered: 0, opened: 0, clicked: 0, failed: 0 }
  customContacts Json? // Stores [{ name, email, phone }] for manual overrides
  sentAt         DateTime?
  createdById    String?
  createdAt      DateTime     @default(now())

  outboxItems Outbox[]

  @@index([createdAt])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Email/phone unsubscribe suppression list (CAN-SPAM). `contact` is the lowercased email or E.164 phone.
model Suppression {
  contact   String   @id
  reason    String?
  createdAt DateTime @default(now())
}

// ── Stall add-ons (R4.2 / vendor-portal §5, admin-portal §6.5) ──────────────────────────────
// Admin-CRUD extras a BOOKED vendor can order per event (table, chairs, power, signage…).
// Prices admin-entered, integer paise (locked rules). Stock guarded by conditional UPDATE on
// `sold` (same oversold pattern as tickets). Orders pay via a separate Razorpay order, fulfilled
// idempotently by the shared webhook (branch on the BookingAddOnOrder lookup).

enum AddOnOrderStatus {
  PENDING_PAYMENT
  PAID
  CANCELLED
}

model StallAddOn {
  id            String   @id @default(cuid())
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name          String
  pricePaise    Int
  maxPerBooking Int      @default(5)
  stock         Int? // null = unlimited
  sold          Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lines         BookingAddOn[]

  @@index([eventId])
}

model BookingAddOnOrder {
  id             String           @id @default(cuid())
  bookingId      String
  booking        Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  status         AddOnOrderStatus @default(PENDING_PAYMENT)
  gatewayOrderId String?          @unique
  totalPaise     Int
  payment        Payment?
  lines          BookingAddOn[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([bookingId])
}

model BookingAddOn {
  id         String            @id @default(cuid())
  orderId    String
  order      BookingAddOnOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  addOnId    String
  addOn      StallAddOn        @relation(fields: [addOnId], references: [id])
  qty        Int
  pricePaise Int // snapshot at order time (integer paise)

  @@index([orderId])
  @@index([addOnId])
}

// ── Happening Strip (R6.3 / customer-portal §3) ──────────────────────────────────────────────
// The event "heartbeat": manual items (announcements, sponsor, facility…) the admin schedules.
// Schedule items + live offers are merged in at query time (server/content/happening.ts) — not
// duplicated here. Visibility is a query-time window (auto-hide/expire); no stale content.
enum HappeningKind {
  LIVE_NOW
  STARTING_SOON
  OFFER
  ANNOUNCEMENT
  SPONSOR
  ACTIVITY
  WORKSHOP
  PERFORMANCE
  FACILITY
}

model HappeningItem {
  id        String        @id @default(cuid())
  eventId   String
  event     Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  kind      HappeningKind @default(ANNOUNCEMENT)
  emoji     String?
  title     String
  detail    String?
  href      String?
  priority  Int           @default(0) // manual weight within a kind (higher first)
  startsAt  DateTime? // visibility window opens (null = immediately)
  endsAt    DateTime? // visibility window closes / auto-expire (null = until unpublished)
  published Boolean       @default(false)
  archived  Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([eventId, published, archived])
}

