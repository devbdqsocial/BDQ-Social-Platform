# BDQ Social — environment template. Copy to .env and fill. Secrets are server-side only.
# See Docs/project.md §18 and Docs/ARCHITECTURE.md §20.

# App
APP_BASE_DOMAIN=bdqsocial.com
SESSION_SECRET=
CRON_SECRET=
# Dev-only: treat the admin/vendor zones as seeded accounts (skip real login). NEVER true in prod.
DEV_ADMIN=false
DEV_VENDOR=false
# Testing only: comma-list of admin emails that may sign in WITHOUT TOTP. Leave empty for real launch.
ADMIN_NO_2FA_EMAILS=

# Error monitoring (Sentry, free tier) — leave empty to disable entirely
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Database (Neon) — pooled for runtime, direct for migrations
DATABASE_URL=
DATABASE_URL_DIRECT=

# Firebase Auth (client/web config — public). ID tokens are verified server-side via Google's
# public keys (jose) using the projectId, so the Admin SDK service account is optional.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Razorpay — slice 2
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Campaign delivery-status webhook (HMAC shared secret; campaigns 401 without it)
CAMPAIGN_WEBHOOK_SECRET=

# WhatsApp - official Cloud API (recommended), Interakt, or OpenWA. Dormant until one is configured.
# WHATSAPP_PROVIDER: cloud | interakt | openwa (auto-detected from the keys below if unset)
WHATSAPP_PROVIDER=
# Cloud API (Meta Graph API): https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_CLOUD_PHONE_ID=
WHATSAPP_CLOUD_API_VERSION=v21.0
WHATSAPP_TEMPLATE_TICKET=ticket_confirmation
# Coming-soon waitlist confirmation (provider-approved template, one body var {{1}} = site link)
WHATSAPP_TEMPLATE_WAITLIST=waitlist_confirm
# Admin campaign template names and body variables are stored per campaign.
WHATSAPP_TEMPLATE_LANG=en
# Interakt (alternate BSP)
INTERAKT_API_KEY=
INTERAKT_BASE_URL=
INTERAKT_TEMPLATE_TICKET=
INTERAKT_TEMPLATE_WAITLIST=
# OpenWA (self-hosted on Render/VPS; BDQ calls its REST API)
# Render service name: bdq-social-openwa
# Example URL: https://bdq-social-openwa.onrender.com
OPENWA_BASE_URL=
OPENWA_API_KEY=
OPENWA_SESSION_ID=
OPENWA_TIMEOUT_MS=15000
OPENWA_SEND_TICKET_QR=true
OPENWA_CAMPAIGN_THROTTLE_MS=1500
OPENWA_TEST_TO=

# SendGrid (email) — slice 2
SENDGRID_API_KEY=
EMAIL_FROM=

# Cloudinary (assets) — slice 2
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Feature Flags
NEXT_PUBLIC_IS_COMING_SOON=true
